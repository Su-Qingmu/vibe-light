#!/usr/bin/env python3
"""
vl - Vibe Light CLI

用法:
  vl thinking                       # 切到 thinking (默认 oc client)
  vl oc.thinking                    # 指定 client
  vl busy                           # 切到 busy
  vl off                            # 全灭
  vl bright 80                      # 设亮度
  vl status                         # 查询 ESP32 状态
  vl ping                           # 健康检查

实现要点:
- 用全局长连接（避免 client 断开触发 DISCONNECTED）
- 单进程多命令，命令间 keep-alive
- 进程退出时优雅断开
"""
import sys
import os
import socket
import time
import json
import argparse
import atexit
from pathlib import Path

# ============== Config ==============
DEFAULT_HOST = "192.168.0.236"
DEFAULT_PORT = 8888
DEFAULT_CLIENT = "oc"
DEFAULT_TIMEOUT = 2.0

# 允许的状态（动画 + 静态）
VALID_STATES = {
    # 动画状态
    "thinking", "coding", "busy", "waiting", "success", "error", "alarm", "loading",
    # 静态状态
    "off", "idle", "permission", "done", "question",
}

VALID_CLIENTS = {"oc", "oo", "cc"}

# ============== Daemon Communication ==============

DAEMON_SOCK = "/tmp/vl-daemon.sock"


def send_via_daemon(cmd, timeout=3):
    """通过 unix socket 发送给 vld 守护进程，由 daemon 维护 TCP 长连接"""
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(timeout)
    try:
        s.connect(DAEMON_SOCK)
        s.sendall((cmd + "\n").encode())
        resp = b""
        while b"\n" not in resp:
            chunk = s.recv(1024)
            if not chunk:
                raise ConnectionResetError("daemon closed")
            resp += chunk
        return resp.decode().strip()
    finally:
        try: s.close()
        except: pass


# ============== UDP Discovery ==============

UDP_DISCOVERY_PORT = 5000
UDP_DISCOVERY_TIMEOUT = 3.0


def discover_esp():
    """听 UDP 5000,返回第一个发现的 ESP32 IP+port (默认 8888)"""
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(("0.0.0.0", UDP_DISCOVERY_PORT))
    s.settimeout(UDP_DISCOVERY_TIMEOUT)
    start = time.time()
    try:
        while time.time() - start < UDP_DISCOVERY_TIMEOUT:
            try:
                data, addr = s.recvfrom(1024)
            except socket.timeout:
                break
            text = data.decode().strip()
            if text.startswith("vibe-light:"):
                # Format: "vibe-light:v2 ip=... tcp_port=8888"
                parts = text.split()
                ip = addr[0]
                port = 8888
                for p in parts[1:]:
                    if p.startswith("ip="):
                        ip = p.split("=", 1)[1]
                    elif p.startswith("tcp_port="):
                        try: port = int(p.split("=", 1)[1])
                        except: pass
                return ip, port
    finally:
        s.close()
    return None, None


def resolve_host():
    """智能选 ESP32:环境变量 > UDP 发现 > 默认 IP"""
    if os.environ.get("VIBE_HOST"):
        return os.environ.get("VIBE_HOST"), int(os.environ.get("VIBE_PORT", DEFAULT_PORT))
    # UDP 发现
    ip, port = discover_esp()
    if ip:
        return ip, port
    # Fallback
    return DEFAULT_HOST, DEFAULT_PORT


# ============== Global Socket (fallback direct) ==============
_SOCK = None
_SOCK_HOST = None
_SOCK_PORT = None


def get_sock(host, port):
    """获取/复用全局 socket（单进程长连接，daemon 不在时用）"""
    global _SOCK, _SOCK_HOST, _SOCK_PORT
    if _SOCK is not None and _SOCK_HOST == host and _SOCK_PORT == port:
        try:
            _SOCK.getpeername()
            return _SOCK
        except (OSError, BrokenPipeError):
            try: _SOCK.close()
            except: pass
            _SOCK = None

    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(DEFAULT_TIMEOUT)
    s.connect((host, port))
    s.settimeout(None)
    _SOCK = s
    _SOCK_HOST = host
    _SOCK_PORT = port
    return s


def send_cmd(host, port, cmd, expect_response=True):
    """优先走 daemon, daemon 不在时直连 ESP32"""
    # 尝试 daemon
    if os.path.exists(DAEMON_SOCK):
        try:
            return send_via_daemon(cmd)
        except Exception:
            pass  # daemon 异常,fallback 到直连

    s = get_sock(host, port)
    try:
        s.sendall((cmd + "\n").encode())
    except (BrokenPipeError, ConnectionResetError, OSError):
        try: s.close()
        except: pass
        global _SOCK
        _SOCK = None
        s = get_sock(host, port)
        s.sendall((cmd + "\n").encode())

    if not expect_response:
        return ""

    s.settimeout(2)
    try:
        resp = b""
        while b"\n" not in resp:
            chunk = s.recv(64)
            if not chunk:
                raise ConnectionResetError("server closed")
            resp += chunk
        s.settimeout(None)
        return resp.decode().strip()
    except socket.timeout:
        s.settimeout(None)
        return "(timeout)"


@atexit.register
def cleanup():
    global _SOCK
    if _SOCK is not None:
        try: _SOCK.close()
        except: pass
        _SOCK = None


# ============== Subcommands ==============

def cmd_state(host, port, args):
    """vl [client.]state"""
    if len(args) != 1:
        print("用法: vl <client>.<state>  或  vl <state>")
        sys.exit(1)
    target = args[0]
    if "." in target:
        client, state = target.split(".", 1)
    else:
        client, state = DEFAULT_CLIENT, target

    if client not in VALID_CLIENTS:
        print(f"❌ client 必须是 {VALID_CLIENTS} 之一")
        sys.exit(1)
    if state not in VALID_STATES:
        print(f"❌ state 必须是 {VALID_STATES} 之一")
        sys.exit(1)

    resp = send_cmd(host, port, f"STATE {client}.{state}")
    print(resp)


def cmd_client(host, port, args):
    if len(args) != 1 or args[0] not in VALID_CLIENTS:
        print("用法: vl --client <oc|oo|cc>")
        sys.exit(1)
    resp = send_cmd(host, port, f"CLIENT {args[0]}")
    print(resp)


def cmd_bright(host, port, args):
    if len(args) != 1:
        print("用法: vl bright <0-100>")
        sys.exit(1)
    try:
        n = int(args[0])
        if not 0 <= n <= 100:
            raise ValueError
    except ValueError:
        print("❌ brightness 必须是 0-100 的整数")
        sys.exit(1)
    resp = send_cmd(host, port, f"BRIGHT {n}")
    print(resp)


def cmd_status(host, port, args):
    resp = send_cmd(host, port, "STATUS")
    try:
        d = json.loads(resp)
        print(json.dumps(d, indent=2, ensure_ascii=False))
    except json.JSONDecodeError:
        print(resp)


def cmd_ping(host, port, args):
    resp = send_cmd(host, port, "PING")
    print(resp)


def cmd_off(host, port, args):
    resp = send_cmd(host, port, f"STATE {DEFAULT_CLIENT}.off")
    print(resp)


def cmd_help(host, port, args):
    print("""
vl - Vibe Light CLI

用法:
  vl <client>.<state>     # 切状态 (e.g. vl oc.thinking)
  vl <state>              # 切状态（默认 oc）
  vl off                  # 全灭
  vl bright <0-100>       # 设亮度
  vl status               # 查询当前状态
  vl ping                 # 健康检查
  vl --client <oc|oo|cc>  # 切激活 client
  vl --host <ip>          # 指定 ESP32 IP
  vl help                 # 帮助

允许的状态:
  动画: thinking coding busy waiting success error alarm loading
  静态: off idle permission done question
""")


# ============== Main ==============

def main():
    try:
        _main_inner()
    except (ConnectionRefusedError, socket.timeout, OSError) as e:
        print("❌ 无法连接 ESP32 (" + type(e).__name__ + ": " + str(e) + ")")
        print("   检查: ESP32 上电? 在同一 WiFi? 启动 vld daemon?")
        sys.exit(1)


def _main_inner():
    parser = argparse.ArgumentParser(description="Vibe Light CLI", add_help=False)
    parser.add_argument("--host", default=None, help="ESP32 IP (overrides UDP discovery)")
    parser.add_argument("--port", default=None, type=int, help="ESP32 TCP port")
    parser.add_argument("--client", choices=list(VALID_CLIENTS), default=DEFAULT_CLIENT)
    parser.add_argument("--no-discover", action="store_true", help="Skip UDP discovery, use defaults")
    parser.add_argument("-h", "--help", action="store_true")
    args, remaining = parser.parse_known_args()

    # Smart host resolution
    if args.host:
        host = args.host
        port = args.port or int(os.environ.get("VIBE_PORT", DEFAULT_PORT))
    elif args.no_discover or os.environ.get("VIBE_HOST"):
        host = os.environ.get("VIBE_HOST", DEFAULT_HOST)
        port = int(os.environ.get("VIBE_PORT", DEFAULT_PORT))
    else:
        host, port = resolve_host()

    if args.help or (not remaining):
        cmd_help(host, port, [])
        return

    subcmd = remaining[0]
    subargs = remaining[1:]

    # 映射子命令 (现在传 host/port 而不是 args.host/args.port)
    if subcmd == "help":
        cmd_help(host, port, [])
    elif subcmd == "status":
        cmd_status(host, port, subargs)
    elif subcmd == "ping":
        cmd_ping(host, port, subargs)
    elif subcmd == "off":
        cmd_off(host, port, subargs)
    elif subcmd == "bright":
        cmd_bright(host, port, subargs)
    elif subcmd == "--client":
        cmd_client(host, port, subargs)
    elif "." in subcmd or subcmd in VALID_STATES:
        cmd_state(host, port, [subcmd])
    else:
        print(f"❌ 未知命令: {subcmd}")
        print("运行 'vl help' 看用法")
        sys.exit(1)


if __name__ == "__main__":
    main()